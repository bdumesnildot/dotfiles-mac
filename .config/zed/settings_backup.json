// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  // -- GENERAL
  "code_actions_on_format": {
    "source.fixAll.eslint": true,
    "source.addMissingImports.ts": true,
    "source.removeUnusedImports": true,
  },
  "debugger": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "right",
  },
  "context_servers": {},
  "buffer_font_weight": 400.0,
  "buffer_line_height": "comfortable",
  "use_system_path_prompts": true,
  "git_panel": {
    "tree_view": true,
    "sort_by_path": false,
  },
  "tabs": {
    "file_icons": true,
    "git_status": true,
    "close_position": "right",
  },
  "icon_theme": "Material Icon Theme",
  "base_keymap": "VSCode",
  "autosave": "on_focus_change",
  "restore_on_startup": "last_session",
  // -- EDITOR
  "format_on_save": "on",
  "soft_wrap": "editor_width",
  "colorize_brackets": true,
  "languages": {
    "TypeScript": {
      "code_actions_on_format": {
        "source.addMissingImports.ts": true,
        "source.fixAll.eslint": true,
      },
    },
  },
  "inlay_hints": {
    "enabled": true,
  },
  // -- LSP
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "preferences": {
            "preferTypeOnlyAutoImports": true,
          },
          "inlayHints": {
            "parameterNames": {
              "enabled": false,
              "suppressWhenArgumentMatchesName": false,
            },
            "parameterTypes": {
              "enabled": false,
            },
            "variableTypes": {
              "enabled": false,
              "suppressWhenTypeMatchesName": true,
            },
            "propertyDeclarationTypes": {
              "enabled": false,
            },
            "functionLikeReturnTypes": {
              "enabled": false,
            },
            "enumMemberValues": {
              "enabled": false,
            },
          },
        },
        // "javascript": {
        //   "inlayHints": {
        //     "parameterNames": {
        //       "enabled": "all",
        //       "suppressWhenArgumentMatchesName": false
        //     },
        //     "parameterTypes": {
        //       "enabled": true
        //     },
        //     "variableTypes": {
        //       "enabled": true,
        //       "suppressWhenTypeMatchesName": true
        //     },
        //     "propertyDeclarationTypes": {
        //       "enabled": true
        //     },
        //     "functionLikeReturnTypes": {
        //       "enabled": true
        //     },
        //     "enumMemberValues": {
        //       "enabled": true
        //     }
        //   }
        // }
      },
    },
  },
  // -- File types
  "file_types": {
    "Markdown": ["md", "mdx"],
  },
  // -- AI
  "edit_predictions": {
    "provider": "copilot",
    "disabled_globs": [],
  },
  "language_models": {},
  "agent": {
    "favorite_models": [
      {
        "provider": "copilot_chat",
        "model": "claude-sonnet-4.5",
      },
      {
        "provider": "google",
        "model": "gemini-3-pro-preview",
      },
      {
        "provider": "google",
        "model": "gemini-3-flash-preview",
      },
      {
        "provider": "copilot_chat",
        "model": "claude-opus-4.6",
      },
    ],
    "default_model": {
      "provider": "google",
      "model": "gemini-3-flash-preview",
    },
    "inline_alternatives": [
      {
        "provider": "zed.dev",
        "model": "gpt-4-mini",
      },
      {
        "provider": "zed.dev",
        "model": "gemini-2.5-flash",
      },
    ],
    "always_allow_tool_actions": false,
    "profiles": {
      "write": {
        "name": "Write",
        "tools": {
          "terminal": true,
          "batch_tool": true,
          "code_symbols": true,
          "copy_path": false,
          "create_file": true,
          "delete_path": false,
          "diagnostics": true,
          "edit_file": true,
          "fetch": true,
          "list_directory": true,
          "move_path": false,
          "now": true,
          "find_path": true,
          "read_file": true,
          "grep": true,
          "symbol_info": true,
          "thinking": true,
          "create_directory": true,
        },
      },
    },
  },
  // -- REMOTE DEVELOPMENT
  "ssh_connections": [
    {
      "host": "heliumlab",
      "args": [],
      "projects": [
        {
          "paths": ["/home/bdm/dev"],
        },
        {
          "paths": ["/home/bdm/server"],
        },
      ],
    },
    {
      "host": "jarvis",
      "args": [],
      "projects": [
        {
          "paths": ["/home/bdm/server"],
        },
      ],
    },
  ],
  // -- THEME
  "theme": "VSCode Dark Modern",
  "theme_overrides": {
    "VSCode Dark Modern": {
      "syntax": {
        "attribute": {
          "font_style": "italic",
        },
      },
    },
  },
  // -- FONT
  "buffer_font_family": "Menlo",
  "show_wrap_guides": false,
  "terminal": {
    "dock": "right",
    "font_family": "GeistMono Nerd Font",
    "font_size": 14,
    "blinking": "terminal_controlled",
    "button": true,
    "copy_on_select": true,
  },
  "ui_font_family": ".SystemUIFont",
  "file_finder": {
    "file_icons": true,
    "modal_max_width": "medium",
  },
  "ui_font_features": {
    "calt": true,
  },
  "ui_font_size": 16.0,
  "buffer_font_size": 14.0,
  // -- MISC.
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "line_indicator_format": "long",
}
