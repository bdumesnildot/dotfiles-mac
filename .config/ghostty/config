# Ghostty Configuration File

shell-integration = zsh
#command = /bin/zsh --login
command = /bin/zsh --login -c "echo 'open tmux popina session' && ~/.config/tmux/launch/launch_popina_web.sh && exec /bin/zsh"

copy-on-select = true
clipboard-read = allow
clipboard-write = allow

window-theme = dark
theme = Custom-dark-plus-vscode

maximize = true

window-padding-x = 16
window-padding-y = 6
font-size = 13

background-opacity = 0.7
background-blur = 50

# Keybindings
keybind = shift+enter=text:\x1b\r
